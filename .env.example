# Copy to .env.local for local dev. NEVER commit .env / .env.local.
# In production, set these in the Vercel dashboard → Project → Settings → Environment Variables.

# Telegram bot used to forward leads. Create a fresh bot via @BotFather
# AFTER revoking the old hard-coded token. Treat the old token as burned.
TELEGRAM_BOT_TOKEN=

# The destination group / channel id (negative number for groups).
TELEGRAM_CHAT_ID=-1002347061578

# Cloudflare Turnstile keys: dashboard.cloudflare.com → Turnstile.
# Site key is public (used in the browser); secret key is server-only.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional overrides
ALLOWED_ORIGIN=https://madami.uz
RATE_LIMIT_PER_MIN=5
